# Database
MONGODB_URI=mongodb://localhost:27017/aerodoc

# JWT
JWT_SECRET=your_jwt_secret_here

# Frontend
FRONTEND_BASE_URL=http://localhost:5173

# OnlyOffice Document Server (Legacy)
ONLYOFFICE_DOC_SERVER_URL=http://localhost:8000
ONLYOFFICE_JWT_SECRET=your_onlyoffice_jwt_secret

# Microsoft Office 365 Configuration
MICROSOFT_CLIENT_ID=your_azure_app_client_id
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret
MICROSOFT_TENANT_ID=your_azure_tenant_id
MICROSOFT_REDIRECT_URI=http://localhost:5173/auth/microsoft/callback

# Collabora Online Configuration
# Option 1: Local Docker (nécessite Docker Desktop)
# COLLABORA_SERVER_URL=http://localhost:9980

# Option 2: Serveur de démo (pour tests uniquement)
COLLABORA_SERVER_URL=https://collabora-online-demo.collaboraoffice.com
WOPI_SECRET=your-secure-wopi-secret-key

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# File Upload
MAX_FILE_SIZE=50MB
UPLOAD_PATH=./uploads
