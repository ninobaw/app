# Configuration de la base de données MongoDB
MONGO_URI=mongodb://localhost:27017/aerodoc

# Configuration du serveur
PORT=5000
FRONTEND_BASE_URL=http://localhost:3000

# Configuration JWT
JWT_SECRET=votre_secret_jwt
JWT_EXPIRE=30d

# Configuration SMTP Office 365
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=votre_email@domaine.com
SMTP_PASSWORD=votre_mot_de_passe
EMAIL_FROM=votre_email@domaine.com
EMAIL_FROM_NAME=SGDO

# Configuration OnlyOffice (optionnel)
ONLYOFFICE_DOC_SERVER_URL=
ONLYOFFICE_JWT_SECRET=

# Configuration Twilio (optionnel)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Configuration Microsoft Copilot / Office 365 (pour traduction)
OFFICE365_CLIENT_ID=votre-client-id
OFFICE365_CLIENT_SECRET=votre-client-secret
OFFICE365_TENANT_ID=votre-tenant-id
OFFICE365_REDIRECT_URI=http://localhost:3000/auth/callback
