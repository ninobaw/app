# ======================
# Configuration Réseau
# ======================
NODE_ENV=development
HOST=10.20.14.148
PORT=64760
VITE_API_BASE_URL=http://10.20.14.148:64760
FRONTEND_PORT=8080
FRONTEND_BASE_URL=http://10.20.14.148:8080

# ======================
# Base de Données
# ======================
MONGODB_URI=mongodb://localhost:27017/aerodoc

# ======================
# Sécurité
# ======================
JWT_SECRET=your_secure_jwt_secret_change_me
COOKIE_SECRET=your_secure_cookie_secret_change_me

# ======================
# Application
# ======================
VITE_APP_TITLE=SGDO - Gestion Documentaire
VITE_APP_VERSION=1.0.0

# ======================
# Collabora Online
# ======================
COLLABORA_SERVER_URL=https://collabora-online-demo.collaboraoffice.com
COLLABORA_WOPI_SECRET=demo-secret-key-2024
COLLABORA_STORAGE_PATH=./storage/documents
COLLABORA_MAX_FILE_SIZE=10485760
COLLABORA_ALLOWED_EXTENSIONS=doc,docx,xls,xlsx,ppt,pptx,odt,ods,odp,rtf,txt,html,htm,csv,pdf
COLLABORA_CALLBACK_URL=/api/collabora/callback
WOPI_SECRET=demo-secret-key-2024

# ======================
# Microsoft Office 365
# ======================
MICROSOFT_CLIENT_ID=your_azure_app_client_id
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret
MICROSOFT_TENANT_ID=your_azure_tenant_id
MICROSOFT_REDIRECT_URI=${FRONTEND_BASE_URL}/auth/microsoft/callback

# ======================
# Configuration Email
# ======================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password
EMAIL_FROM="SGDO <noreply@votredomaine.com>"

# ======================
# Fichiers et Téléchargements
# ======================
MAX_FILE_SIZE=50MB
UPLOAD_PATH=./uploads

# ======================
# Configuration CORS
# ======================
CORS_ORIGIN=${FRONTEND_BASE_URL}
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_CREDENTIALS=true
